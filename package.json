{
  "name": "tabs-organizer",
  "displayName": "Branch Tabs Manager",
  "description": "Save and restore opened tabs automatically per Git branch",
  "version": "0.1.0",
  "publisher": "nel386",
  "author": {
    "name": "nel386"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nel386/tabs-organizer"
  },
  "bugs": {
    "url": "https://github.com/nel386/tabs-organizer/issues"
  },
  "keywords": [
    "git",
    "tabs",
    "branch",
    "workspace",
    "productivity",
    "context"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.108.1"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "branchTabs.saveTabs",
        "title": "Branch Tabs: Save Current Tabs"
      },
      {
        "command": "branchTabs.restoreTabs",
        "title": "Branch Tabs: Restore Tabs for Current Branch"
      },
      {
        "command": "branchTabs.showQuickMenu",
        "title": "Branch Tabs: Show Menu"
      },
      {
        "command": "branchTabs.loadFromBranch",
        "title": "Load Tabs from Another Branch..."
      }
    ],
    "menus": {
      "editor/title/context": [
        {
          "command": "branchTabs.loadFromBranch",
          "group": "branchTabs@1"
        }
      ]
    },
    "configuration": {
      "title": "Branch Tabs",
      "properties": {
        "branchTabs.autoRestore": {
          "type": "boolean",
          "default": true,
          "description": "Automatically restore tabs when switching branches"
        },
        "branchTabs.autoSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically save tabs when they change"
        },
        "branchTabs.showNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show notifications when saving/restoring tabs"
        },
        "branchTabs.autoSaveDelay": {
          "type": "number",
          "default": 2000,
          "description": "Delay in milliseconds before auto-saving tabs (debounce)",
          "minimum": 500,
          "maximum": 10000
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "check-types": "tsc --noEmit",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
